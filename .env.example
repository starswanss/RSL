# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามต้องการ

# ฐานข้อมูล PostgreSQL (Neon) — ใช้ connection string แบบ pooled (มี -pooler)
# ตัวอย่าง: postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/rsl?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# กุญแจเข้ารหัส session แอดมิน — ใช้ค่าสุ่มยาว ๆ ตอนใช้งานจริง (openssl rand -hex 32)
AUTH_SECRET="เปลี่ยนเป็นค่าสุ่มยาว-อย่างน้อย-32-ตัวอักษร"

# บัญชีแอดมินเริ่มต้น (ใช้ตอน seed ครั้งแรก) — เปลี่ยนรหัสก่อนใช้งานจริง
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="rsladmin123"

# UploadThing — ที่เก็บรูปหลักฐานที่ผู้ส่งผลอัปโหลด (สมัครฟรีที่ uploadthing.com)
# เอา token จาก Dashboard > API Keys
UPLOADTHING_TOKEN=""
